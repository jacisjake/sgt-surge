# ─── tastytrade Authentication ─────────────────────────────────────────────────
# NEVER commit your actual .env file to version control.
#
# Option 1: OAuth (recommended)
#   1. Create an OAuth app at https://developer.tastytrade.com
#   2. Note your Client ID and Client Secret
#   3. Generate a refresh token:
#      - Use "Create Grant" in the developer portal, OR
#      - Complete the OAuth flow from the bot's dashboard at /trader/oauth/callback
#   4. Fill in the three values below
#
TT_CLIENT_ID=your_oauth_client_id
TT_CLIENT_SECRET=your_oauth_client_secret
TT_REFRESH_TOKEN=your_refresh_token

# Option 2: Legacy username/password (deprecated -- may stop working)
# TT_USERNAME=your_tastytrade_username
# TT_PASSWORD=your_tastytrade_password

# Your tastytrade account number (required for both auth methods)
TT_ACCOUNT_NUMBER=your_account_number

# If the bot is behind a reverse proxy, set this to match the redirect URI
# in your tastytrade developer portal exactly.
# TT_OAUTH_REDIRECT_URI=https://your-domain.com/trader/oauth/callback

# ─── Trading Mode ──────────────────────────────────────────────────────────────
# 'paper' = paper trading (no real money), 'live' = real money
TRADING_MODE=paper

# ─── Risk Management ──────────────────────────────────────────────────────────
# Max risk per trade as fraction of account (0.02 = 2%)
MAX_POSITION_RISK_PCT=0.02

# Max total portfolio risk as fraction of account (0.10 = 10%)
MAX_PORTFOLIO_RISK_PCT=0.10

# Max concurrent open positions
MAX_POSITIONS=5

# Max drawdown before halting trading (0.15 = 15%)
MAX_DRAWDOWN_PCT=0.15

# ─── Data Providers ───────────────────────────────────────────────────────────
# Financial Modeling Prep API key (optional, free tier: 250 requests/day)
# Used for float data enrichment. Without this, float filtering is disabled.
# Get one at: https://financialmodelingprep.com/developer/docs/
# FMP_API_KEY=your_fmp_api_key

# ─── Logging ──────────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, or ERROR
LOG_LEVEL=INFO
